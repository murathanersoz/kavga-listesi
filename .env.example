# Kavga Listesi — copy to .env. EVERYTHING IS OPTIONAL; the app runs with zero keys.

# Public origin (QR codes + join links point here). Set to your domain in prod.
PUBLIC_URL=http://localhost:3001

# OPTIONAL — YouTube Data API v3 key. Enables in-app search on phones.
# Without it the app is fully functional in link-paste mode.
# Get one at https://console.cloud.google.com (YouTube Data API v3, free quota).
YOUTUBE_API_KEY=

# Server port (default 3001) and SQLite path (default ./kavga.db)
# PORT=3001
# KAVGA_DB=./kavga.db
